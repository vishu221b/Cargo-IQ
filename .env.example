# Copy to .env (which is gitignored) before running docker compose.
# Anything you don't set falls back to the defaults baked into application.yml
# / docker-compose.yml.

# ===========================================================================
# Model provider selection
# ===========================================================================
# DEFAULT IS A MOCK — no API key needed to run. The mock chat + embedding make
# the whole RAG pipeline work offline. Chat is also selectable per-request from
# the UI (mock / ollama / a configured provider). Set these only to change the
# SERVER DEFAULT — see docs/model-providers.md.
#   chat:      mock | openai | anthropic | google-genai | ollama
#   embedding: none (-> mock) | openai | google-genai | ollama
# AI_CHAT_PROVIDER=mock
# AI_EMBEDDING_PROVIDER=none
#
# The pgvector column width must match the active embedding model. The mock and
# OpenAI default are 1536; Gemini/Ollama embeddings are 768.
# VECTOR_DIMENSIONS=1536

# --- OpenAI (optional; only when AI_*_PROVIDER=openai) ----------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic / Claude (chat only — no embedding model) -------------------
# https://console.anthropic.com/  — pair with another embedding provider.
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5

# --- Google Gemini (AI Studio, API-key based; chat + embedding) ------------
# https://aistudio.google.com/apikey
# Chat is runtime-switchable (AI_CHAT_PROVIDER=google-genai). For Gemini
# EMBEDDINGS, run with SPRING_PROFILES_ACTIVE=dev,gemini (see docs/model-providers.md).
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Ollama (fully local, NO API key — easiest way to run end-to-end) ------
# Install ollama, then: `ollama pull llama3.1 && ollama pull nomic-embed-text`
# Activate with SPRING_PROFILES_ACTIVE=dev,ollama (sets VECTOR_DIMENSIONS=768).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Postgres (docker-compose sets these inside the network) ---------------
# Only override if running the app outside docker-compose.
# POSTGRES_URL=jdbc:postgresql://localhost:5432/cargoiq
# POSTGRES_USER=cargoiq
# POSTGRES_PASSWORD=cargoiq

# ===========================================================================
# Security (JWT + RBAC)
# ===========================================================================
# MUST be overridden outside local dev. Minimum 32 bytes (256 bits) for HS256.
# JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
# JWT_ISSUER=cargo-iq
# JWT_TTL_SECONDS=3600
# Dev-profile bootstrap admin (seeded on first run under the `dev` profile):
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=admin12345

# --- Server ---------------------------------------------------------------
# SERVER_PORT=8080
# SPRING_PROFILES_ACTIVE=dev
